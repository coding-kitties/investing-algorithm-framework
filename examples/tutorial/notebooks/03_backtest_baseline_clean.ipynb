    " \"cells\": [\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": [\n",
    "    \"# Backtest baseline\\n\",\n",
    "    \"\\n\",\n",
    "    \"This notebooks demonstrates a baseline backtesting workflow using vector backtests and event backtests.\\n\"\n",
    "   ],\n",
    "   \"id\": \"fcef781cac89c306\"\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"initial_id\",\n",
    "   \"metadata\": {\n",
    "    \"collapsed\": true\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"import sys\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Add parent directory to path so we can import from strategies/\\n\",\n",
    "    \"sys.path.insert(0, str(Path.cwd().parent))\\n\",\n",
    "    \"\\n\",\n",
    "    \"from strategies.ema_crossover_rsi_filter.strategy import EMACrossoverRSIFFilterStrategy\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": \"Strategy = EMACrossoverRSIFFilterStrategy\",\n",
    "   \"id\": \"bbcec2c05f4c5034\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": \"## Constants\",\n",
    "   \"id\": \"ceefe8f6094d0fff\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"from datetime import datetime, timezone\\n\",\n",
    "    \"from investing_algorithm_framework import BacktestDateRange\\n\",\n",
    "    \"\\n\",\n",
    "    \"resource_directory = Path.cwd() / \\\"resources\\\"\\n\",\n",
    "    \"data_storage_path = Path.cwd().parent / \\\"data\\\"\\n\",\n",
    "    \"backtest_results_dir = Path.cwd().parent / \\\"backtest_results\\\"\\n\",\n",
    "    \"reports_dir = Path.cwd().parent / \\\"reports\\\"\\n\",\n",
    "    \"figures_dir = reports_dir / \\\"figures\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"backtest_window_date_range = BacktestDateRange(\\n\",\n",
    "    \"    start_date=datetime(2022, 1, 1, tzinfo=timezone.utc),\\n\",\n",
    "    \"    end_date=datetime(2023, 12, 30, tzinfo=timezone.utc)\\n\",\n",
    "    \")\\n\",\n",
    "    \"MARKET = \\\"BITVAVO\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"in_sample_assets = [\\\"BTC\\\", \\\"ETH\\\", \\\"ADA\\\", \\\"SOL\\\", \\\"DOT\\\"]\\n\",\n",
    "    \"out_sample_assets = [\\\"XRP\\\", \\\"LTC\\\", \\\"BCH\\\"]\\n\",\n",
    "    \"time_frames = [\\\"2h\\\", \\\"4h\\\", \\\"1d\\\"]\"\n",
    "   ],\n",
    "   \"id\": \"edbeddb0b89d6711\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": \"## Select parameters\",\n",
    "   \"id\": \"a43f5d253256d4d8\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"params = {\\n\",\n",
    "    \"    \\\"trading_symbol\\\": \\\"EUR\\\",\\n\",\n",
    "    \"    \\\"rsi_timeframe\\\": \\\"2h\\\",\\n\",\n",
    "    \"    \\\"rsi_period\\\": 14,\\n\",\n",
    "    \"    \\\"rsi_overbought_threshold\\\": 75,\\n\",\n",
    "    \"    \\\"rsi_oversold_threshold\\\": 30,\\n\",\n",
    "    \"    \\\"ema_timeframe\\\": \\\"2h\\\",\\n\",\n",
    "    \"    \\\"ema_short_period\\\": 12,\\n\",\n",
    "    \"    \\\"ema_long_period\\\": 26,\\n\",\n",
    "    \"    \\\"ema_cross_lookback_window\\\": 10,\\n\",\n",
    "    \"}\"\n",
    "   ],\n",
    "   \"id\": \"8f5b9659dbc82ab5\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": \"## Initialize strategy\",\n",
    "   \"id\": \"87e95bb3717b16b9\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"from investing_algorithm_framework import TimeUnit\\n\",\n",
    "    \"algorithm_id = \\\"visualization_strategy\\\"\\n\",\n",
    "    \"strategy = Strategy(\\n\",\n",
    "    \"    **params,\\n\",\n",
    "    \"    algorithm_id=algorithm_id,\\n\",\n",
    "    \"    time_unit=TimeUnit.HOUR,\\n\",\n",
    "    \"    interval=2,\\n\",\n",
    "    \"    market=MARKET,\\n\",\n",
    "    \"    symbols=in_sample_assets,\\n\",\n",
    "    \")\"\n",
    "   ],\n",
    "   \"id\": \"a0d28e54beb6e1e3\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": \"## Run event backtest\",\n",
    "   \"id\": \"ed2d397d020f4fca\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"from investing_algorithm_framework import create_app, RESOURCE_DIRECTORY, PortfolioConfiguration, DATA_DIRECTORY\\n\",\n",
    "    \"\\n\",\n",
    "    \"app = create_app(config={RESOURCE_DIRECTORY: resource_directory, DATA_DIRECTORY: data_storage_path})\\n\",\n",
    "    \"app.add_portfolio_configuration(\\n\",\n",
    "    \"    PortfolioConfiguration(initial_balance=1000, market=\\\"BITVAVO\\\", trading_symbol=\\\"EUR\\\")\\n\",\n",
    "    \")\\n\",\n",
    "    \"app.add_strategy(strategy)\"\n",
    "   ],\n",
    "   \"id\": \"ca4681fe9a8c7d33\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": \"event_backtest = app.run_backtest(backtest_date_range=backtest_window_date_range, show_progress=True, fill_missing_data=True)\",\n",
    "   \"id\": \"b68d67567bb24f16\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": \"## Run vector backtest\",\n",
    "   \"id\": \"4f724f647fd8fd96\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"vector_backtest = app.run_vector_backtest(\\n\",\n",
    "    \"    backtest_date_range=backtest_window_date_range, show_progress=True, fill_missing_data=True\\n\",\n",
    "    \")\"\n",
    "   ],\n",
    "   \"id\": \"913c89891011a2d4\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": \"## Display results\",\n",
    "   \"id\": \"8a40680b018404a4\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"from investing_algorithm_framework import create_markdown_table\\n\",\n",
    "    \"from IPython.display import Markdown, display\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Define columns in desired order\\n\",\n",
    "    \"columns = [\\n\",\n",
    "    \"    \\\"total_net_gain\\\",\\n\",\n",
    "    \"    \\\"cagr\\\",\\n\",\n",
    "    \"    \\\"number_of_trades\\\",\\n\",\n",
    "    \"    \\\"sharpe_ratio\\\",\\n\",\n",
    "    \"    \\\"sortino_ratio\\\",\\n\",\n",
    "    \"    \\\"calmar_ratio\\\",\\n\",\n",
    "    \"    \\\"win_rate\\\",\\n\",\n",
    "    \"    \\\"current_win_rate\\\",\\n\",\n",
    "    \"    \\\"win_loss_ratio\\\",\\n\",\n",
    "    \"    \\\"current_win_loss_ratio\\\",\\n\",\n",
    "    \"    \\\"profit_factor\\\",\\n\",\n",
    "    \"    \\\"max_drawdown\\\",\\n\",\n",
    "    \"    \\\"average_trade_return\\\",\\n\",\n",
    "    \"    \\\"annual_volatility\\\",\\n\",\n",
    "    \"]\\n\",\n",
    "    \"percentage_columns = [\\\"cagr\\\", \\\"win_rate\\\", \\\"max_drawdown\\\", \\\"annual_volatility\\\"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Collect backtest summaries with filtered columns in desired order\\n\",\n",
    "    \"backtest_data = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"summary = event_backtest.backtest_summary.to_dict()\\n\",\n",
    "    \"print(summary)\\n\",\n",
    "    \"\\n\",\n",
    "    \"first_run = event_backtest.get_all_backtest_runs()[0]\\n\",\n",
    "    \"print(first_run.backtest_metrics)\\n\",\n",
    "    \"# Filter and order columns, format percentages\\n\",\n",
    "    \"filtered = {}\\n\",\n",
    "    \"for col in columns:\\n\",\n",
    "    \"    value = summary.get(col)\\n\",\n",
    "    \"    if col in percentage_columns and isinstance(value, (int, float)):\\n\",\n",
    "    \"        filtered[col] = f\\\"{value * 100:.2f}%\\\"\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        filtered[col] = value\\n\",\n",
    "    \"backtest_data.append(filtered)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Create markdown table\\n\",\n",
    "    \"table = create_markdown_table(data=backtest_data)\\n\",\n",
    "    \"\\n\",\n",
    "    \"display(Markdown(f\\\"## Event backtest window summary over all windows ({len(event_backtest.get_backtest_date_ranges())} windows)\\\\n\\\\n{table}\\\"))\"\n",
    "   ],\n",
    "   \"id\": \"27916e9b4fce1e4b\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null\n",
    "  },\n",
